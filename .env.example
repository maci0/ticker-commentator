# ── Debug ────────────────────────────────────────────────────────────
APP_DEBUG=0
COMMENTARY_DEBUG=0
ORPHEUS_TTS_DEBUG=0

# ── Commentary LLM (llama.cpp) ──────────────────────────────────────
COMMENTARY_EMOTE_CHANCE_1=0.75    # probability of first Orpheus emotion tag
COMMENTARY_EMOTE_CHANCE_2=0.50    # probability of second emotion tag
COMMENTARY_GGUF_REPO=bartowski/google_gemma-3-4b-it-GGUF
COMMENTARY_GGUF_FILE=google_gemma-3-4b-it-Q4_K_M.gguf
COMMENTARY_CTX=4096
COMMENTARY_GPU_LAYERS=-1          # -1 = all layers on GPU, 0 = CPU only
COMMENTARY_MAIN_GPU=0
COMMENTARY_TENSOR_SPLIT=1.0       # comma-separated for multi-GPU

# ── Orpheus TTS (llama.cpp) ─────────────────────────────────────────
ORPHEUS_GGUF_REPO=isaiahbjork/orpheus-3b-0.1-ft-Q4_K_M-GGUF
ORPHEUS_GGUF_FILE=orpheus-3b-0.1-ft-q4_k_m.gguf
ORPHEUS_LLAMA_CTX=4096
ORPHEUS_LLAMA_BATCH=64
ORPHEUS_LLAMA_GPU_LAYERS=-1       # -1 = all layers on GPU, 0 = CPU only
ORPHEUS_LLAMA_MAIN_GPU=0
ORPHEUS_LLAMA_TENSOR_SPLIT=1.0    # comma-separated for multi-GPU

# ── Orpheus TTS audio ───────────────────────────────────────────────
ORPHEUS_TEMPERATURE=0.6
ORPHEUS_TOP_P=0.9
ORPHEUS_SAMPLE_RATE=24000
ORPHEUS_TTS_MAX_SECONDS=60        # timeout to stop Orpheus repetition
ORPHEUS_CHUNK_FRAMES=24           # SNAC frames per audio chunk
